static/*.gz
static/*.br

# Rust forge — target/ lives at $CARGO_TARGET_DIR (outside repo by
# project convention) but ignore in case anyone overrides.
target/
**/*.rs.bk

# Forge build reports are time-stamped artefacts; keep latest.json
# (the canonical pointer) but ignore the per-run snapshots.
reports/build-*.json
reports/debug-*.log
reports/contrast.json

# Python helpers cache.
__pycache__/
**/__pycache__/

# T56: private signing key — NEVER commit. attest-pubkey.b64 IS
# committed (trust anchor); attest-key.b64 is the private half.
reports/attest-key.b64
.cargo/

# T56b: `forge audit init-hook` writes a per-clone pre-commit hook
# under .githooks/. Operators activate it locally via
# `git config core.hooksPath .githooks`. It's per-clone bootstrap,
# not committed config — checking it in would force every clone to
# share the same hook + bypass paul's intentional per-machine
# override pattern.
.githooks/

# Licensed dreamstime stock pool — 1.3 GB of full-res images
# Deborah Armstrong paid licenses (ingested 2026-05-20).
# Substrate-wide reusable photo pool; rsync to deploy targets.
# Track via git-lfs in a follow-on task if commit-discovery becomes load-bearing.
static/assets/dreamstime/
