use anyhow::Result;
use axum::Router;
use tracing_subscriber::EnvFilter;

#[tokio::main]
async fn main() -> Result<()> {
    // Structured tracing per rule log-001. OTLP-compatible.
    tracing_subscriber::fmt()
        .with_env_filter(EnvFilter::from_default_env())
        .with_target(false)
        .json()
        .init();

    let app = build_router();
    let listener = tokio::net::TcpListener::bind(bind_address()).await?;
    tracing::info!(addr = %listener.local_addr()?, "REPLACE-ME-service listening");
    axum::serve(listener, app).await?;
    Ok(())
}

/// Wire every typed handler here. Each handler must use typed Axum
/// extractors (Json<T>, Query<T>, Path<T>) with `serde(deny_unknown_fields)`
/// on the target struct — rule `sec-001`.
fn build_router() -> Router {
    Router::new()
        .route("/health", axum::routing::get(health))
        // .route("/your-endpoint", axum::routing::post(your_handler))
}

/// Default listen address. Override via env in production.
fn bind_address() -> std::net::SocketAddr {
    let port: u16 = std::env::var("PORT")
        .ok()
        .and_then(|s| s.parse().ok())
        .unwrap_or(3000);
    std::net::SocketAddr::from(([127, 0, 0, 1], port))
}

/// Health endpoint — every HTTP service ships one.
async fn health() -> &'static str {
    "ok"
}

