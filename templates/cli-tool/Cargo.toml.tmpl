# Cargo.toml template for a new CLI tool crate.
#
# Canonical stack (per `[[substrate-only-path]]` doctrine — do NOT
# relitigate):
#   * CLI parsing : clap with derive
#   * Errors      : anyhow at binary boundary, thiserror in libs
#   * Logging     : tracing + tracing-subscriber
#   * Serde       : deny_unknown_fields when reading configs
#   * Conventions : argv pattern matches forge-cli + loom-cli
#
# Steps:
#   1. Copy this file to `crates/<your-crate>/Cargo.toml`.
#   2. Rename `name`, update `description`.
#   3. Add to workspace root `Cargo.toml` members list.

[package]
name = "REPLACE-ME-cli"
version = "0.1.0"
publish = false
edition.workspace = true
rust-version.workspace = true
license.workspace = true
repository.workspace = true
description = "REPLACE — one-sentence purpose of this CLI tool."

[[bin]]
name = "REPLACE-ME"
path = "src/main.rs"

[dependencies]
clap = { workspace = true, features = ["derive", "env"] }
anyhow = { workspace = true }
thiserror = { workspace = true }
tracing = { workspace = true }
tracing-subscriber = { workspace = true, features = ["env-filter"] }
serde = { workspace = true, features = ["derive"] }
serde_json = { workspace = true }
toml = { workspace = true }

[dev-dependencies]
proptest = { workspace = true }
tempfile = { workspace = true }

[lints]
workspace = true
