use anyhow::Result;
use clap::{Parser, Subcommand};
use std::process::ExitCode;
use tracing_subscriber::EnvFilter;

/// REPLACE — one-line description shown in --help.
#[derive(Parser, Debug)]
#[command(version, about)]
struct Cli {
    /// Project root (default = CWD). Convention matches forge-cli +
    /// loom-cli — keep the argv shape consistent.
    #[arg(long, env = "REPLACE_ME_ROOT")]
    root: Option<std::path::PathBuf>,
    /// JSON output (per docs-008 cross-AI compatibility rule).
    #[arg(long, default_value_t = false)]
    json: bool,
    #[command(subcommand)]
    cmd: Cmd,
}

#[derive(Subcommand, Debug)]
enum Cmd {
    /// Default action. REPLACE with real behavior.
    Hello,
}

fn main() -> ExitCode {
    tracing_subscriber::fmt()
        .with_env_filter(EnvFilter::from_default_env())
        .with_target(false)
        .init();

    let cli = Cli::parse();
    match run(&cli) {
        Ok(code) => code,
        Err(e) => {
            tracing::error!(error = %e, "fatal");
            eprintln!("{e:#}");
            ExitCode::from(2)
        }
    }
}

fn run(cli: &Cli) -> Result<ExitCode> {
    match &cli.cmd {
        Cmd::Hello => {
            if cli.json {
                println!("{}", serde_json::json!({"status":"ok","msg":"hello"}));
            } else {
                println!("hello");
            }
            Ok(ExitCode::SUCCESS)
        }
    }
}

