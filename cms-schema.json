{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "additionalProperties": false,
  "definitions": {
    "CmsAvatar": {
      "description": "Wire form of [`ComposerAvatar`].",
      "oneOf": [
        {
          "additionalProperties": false,
          "description": "No avatar slot.",
          "properties": {
            "kind": {
              "enum": [
                "none"
              ],
              "type": "string"
            }
          },
          "required": [
            "kind"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "description": "Display 1-3 letters.",
          "properties": {
            "kind": {
              "enum": [
                "initials"
              ],
              "type": "string"
            },
            "letters": {
              "description": "Letters.",
              "type": "string"
            }
          },
          "required": [
            "kind",
            "letters"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "description": "Display an image.",
          "properties": {
            "alt": {
              "description": "Required alt.",
              "type": "string"
            },
            "kind": {
              "enum": [
                "image"
              ],
              "type": "string"
            },
            "src": {
              "description": "Image src.",
              "type": "string"
            }
          },
          "required": [
            "alt",
            "kind",
            "src"
          ],
          "type": "object"
        }
      ]
    },
    "CmsBannerTone": {
      "description": "Banner tone — closed enum mirroring the standard color roles. Each maps to a `data-tone` attribute the skin styles.",
      "oneOf": [
        {
          "description": "Neutral, primary-tinted (default).",
          "enum": [
            "info"
          ],
          "type": "string"
        },
        {
          "description": "Yellow-tinted; use for time-sensitive / actionable notices.",
          "enum": [
            "warn"
          ],
          "type": "string"
        },
        {
          "description": "Green-tinted; use for confirmations.",
          "enum": [
            "success"
          ],
          "type": "string"
        },
        {
          "description": "Red-tinted; use for errors / critical alerts.",
          "enum": [
            "danger"
          ],
          "type": "string"
        }
      ]
    },
    "CmsCard": {
      "additionalProperties": false,
      "description": "One feed card inside a [`CmsSection::CardFeed`]. Self-contained; no further nesting allowed in v1.",
      "properties": {
        "avatar": {
          "allOf": [
            {
              "$ref": "#/definitions/CmsAvatar"
            }
          ],
          "description": "Avatar slot. Uses the same shape as the Composer avatar so downstream Loom CSS can share the circle treatment."
        },
        "data_backend": {
          "description": "Backend key (verified by phase_phantom_button at build time).",
          "type": "string"
        },
        "host": {
          "description": "Optional sub-line (e.g. \"@court_dax · 4d left\"). Rendered as `<p>` below the title.",
          "type": [
            "string",
            "null"
          ]
        },
        "href": {
          "description": "Primary card link target. Validated by `is_safe_url`.",
          "type": "string"
        },
        "media": {
          "anyOf": [
            {
              "$ref": "#/definitions/CmsCardMedia"
            },
            {
              "type": "null"
            }
          ],
          "description": "T70a: optional 16:9 media slot rendered ABOVE the body. When None, no media block is emitted (card is pure text). When Some, a `<div class=\"loom-card-feed-item__media\">` wraps the asset (image / picture / video). Lazy-load via loading=\"lazy\". Object-fit:cover via skin.css."
        },
        "stats": {
          "default": [],
          "description": "Stats grid below the body. Empty → no grid emitted.",
          "items": {
            "$ref": "#/definitions/CmsCardStat"
          },
          "type": "array"
        },
        "tag": {
          "description": "Optional category tag (small badge above the title).",
          "type": [
            "string",
            "null"
          ]
        },
        "title": {
          "description": "Card title (rendered as h3).",
          "type": "string"
        },
        "tone": {
          "description": "Optional `data-tone` value for the tag chip (curated palette in skin.css: violet/indigo/ocean/forest/amber/rose/ruby/ walnut/slate/teal). When set, drives the chip's bg/fg/border hue. Falls back to the site's primary brand color when None. Sites that need a custom hue should keep `tone` None and emit inline `style=\"--tag-color: …\"` via a future field.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "avatar",
        "data_backend",
        "href",
        "title"
      ],
      "type": "object"
    },
    "CmsCardMedia": {
      "description": "T70a: media slot for [`CmsCard`]. Three shapes: - `Image { src, alt, srcset?, width?, height? }` — `<img loading=\"lazy\">` - `Video { poster?, src, type, alt }` — native `<video>` (no autoplay) - `Placeholder { tone? }` — visible empty media area with gradient bg (no `<img>`/`<video>`), useful while content is being authored. data-empty=\"true\" lets skin.css show a soft pattern.\n\nAll variants are SAFE: src/poster validated by `is_safe_url`; alt is REQUIRED for Image (a11y); type is restricted to known safe MIME values for Video.",
      "oneOf": [
        {
          "additionalProperties": false,
          "description": "Static image. `loading=\"lazy\"`. `decoding=\"async\"`.",
          "properties": {
            "alt": {
              "description": "REQUIRED accessible-name text. Empty string allowed only for purely decorative media (then aria-hidden will be set by the renderer too).",
              "type": "string"
            },
            "height": {
              "description": "See `width`.",
              "format": "uint32",
              "minimum": 0.0,
              "type": [
                "integer",
                "null"
              ]
            },
            "kind": {
              "enum": [
                "image"
              ],
              "type": "string"
            },
            "src": {
              "description": "Resource URL. Validated by `is_safe_url`.",
              "type": "string"
            },
            "srcset": {
              "description": "Optional `srcset` for responsive density (1x/2x/3x).",
              "type": [
                "string",
                "null"
              ]
            },
            "width": {
              "description": "Optional intrinsic dimensions (drives layout-shift avoidance via the rendered width/height attrs).",
              "format": "uint32",
              "minimum": 0.0,
              "type": [
                "integer",
                "null"
              ]
            }
          },
          "required": [
            "alt",
            "kind",
            "src"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "description": "Native HTML `<video>`. No autoplay. controls=true. preload=metadata.",
          "properties": {
            "alt": {
              "description": "Accessible-name (for screen-reader fallback).",
              "type": "string"
            },
            "kind": {
              "enum": [
                "video"
              ],
              "type": "string"
            },
            "mime": {
              "description": "MIME type — must be one of: video/mp4, video/webm, video/ogg.",
              "type": "string"
            },
            "poster": {
              "description": "Optional poster image (shown before play).",
              "type": [
                "string",
                "null"
              ]
            },
            "src": {
              "description": "Video resource URL.",
              "type": "string"
            }
          },
          "required": [
            "alt",
            "kind",
            "mime",
            "src"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "description": "Visible-but-empty media area. CSS gradient placeholder.",
          "properties": {
            "kind": {
              "enum": [
                "placeholder"
              ],
              "type": "string"
            },
            "tone": {
              "description": "Optional `data-tone` to colorize the placeholder.",
              "type": [
                "string",
                "null"
              ]
            }
          },
          "required": [
            "kind"
          ],
          "type": "object"
        }
      ]
    },
    "CmsCardStat": {
      "additionalProperties": false,
      "description": "One {label, value} pair inside a [`CmsCard`]'s stats grid.",
      "properties": {
        "label": {
          "description": "Caption text (e.g. \"Votes\").",
          "type": "string"
        },
        "value": {
          "description": "Value text (e.g. \"78%\").",
          "type": "string"
        }
      },
      "required": [
        "label",
        "value"
      ],
      "type": "object"
    },
    "CmsComposerSize": {
      "description": "Mirror of [`ComposerSize`].",
      "oneOf": [
        {
          "description": "Compact density.",
          "enum": [
            "compact"
          ],
          "type": "string"
        },
        {
          "description": "Comfortable density.",
          "enum": [
            "comfortable"
          ],
          "type": "string"
        }
      ]
    },
    "CmsFit": {
      "description": "Mirror of [`PictureFit`].",
      "oneOf": [
        {
          "description": "Default.",
          "enum": [
            "default"
          ],
          "type": "string"
        },
        {
          "description": "Cover.",
          "enum": [
            "cover"
          ],
          "type": "string"
        },
        {
          "description": "Contain.",
          "enum": [
            "contain"
          ],
          "type": "string"
        }
      ]
    },
    "CmsFormField": {
      "description": "Typed form field. Closed enum — adding a variant requires a renderer arm + test.",
      "oneOf": [
        {
          "additionalProperties": false,
          "description": "Single-line text input.",
          "properties": {
            "hint": {
              "description": "Optional hint paragraph below the input.",
              "type": [
                "string",
                "null"
              ]
            },
            "label": {
              "description": "Visible label.",
              "type": "string"
            },
            "max_length": {
              "description": "`maxlength` attribute (None → unbounded).",
              "format": "uint32",
              "minimum": 0.0,
              "type": [
                "integer",
                "null"
              ]
            },
            "name": {
              "description": "`name` attribute (form-data key).",
              "type": "string"
            },
            "placeholder": {
              "description": "Optional placeholder text.",
              "type": [
                "string",
                "null"
              ]
            },
            "required": {
              "default": false,
              "description": "`required` attribute.",
              "type": "boolean"
            },
            "type": {
              "enum": [
                "text"
              ],
              "type": "string"
            }
          },
          "required": [
            "label",
            "name",
            "type"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "description": "Multi-line text input.",
          "properties": {
            "hint": {
              "description": "Optional hint.",
              "type": [
                "string",
                "null"
              ]
            },
            "label": {
              "description": "Visible label.",
              "type": "string"
            },
            "max_length": {
              "description": "`maxlength` attribute.",
              "format": "uint32",
              "minimum": 0.0,
              "type": [
                "integer",
                "null"
              ]
            },
            "name": {
              "description": "`name` attribute.",
              "type": "string"
            },
            "placeholder": {
              "description": "Optional placeholder.",
              "type": [
                "string",
                "null"
              ]
            },
            "required": {
              "default": false,
              "description": "`required` attribute.",
              "type": "boolean"
            },
            "rows": {
              "default": 4,
              "description": "`rows` attribute (defaults to 4 if omitted).",
              "format": "uint32",
              "minimum": 0.0,
              "type": "integer"
            },
            "type": {
              "enum": [
                "textarea"
              ],
              "type": "string"
            }
          },
          "required": [
            "label",
            "name",
            "type"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "description": "Dropdown.",
          "properties": {
            "hint": {
              "description": "Optional hint.",
              "type": [
                "string",
                "null"
              ]
            },
            "label": {
              "description": "Visible label.",
              "type": "string"
            },
            "name": {
              "description": "`name` attribute.",
              "type": "string"
            },
            "options": {
              "description": "Options list.",
              "items": {
                "$ref": "#/definitions/CmsSelectOption"
              },
              "type": "array"
            },
            "required": {
              "default": false,
              "description": "`required` attribute.",
              "type": "boolean"
            },
            "type": {
              "enum": [
                "select"
              ],
              "type": "string"
            }
          },
          "required": [
            "label",
            "name",
            "options",
            "type"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "description": "Read-only text display (e.g. \"Set automatically: 720p · 30s\").",
          "properties": {
            "hint": {
              "description": "Optional hint.",
              "type": [
                "string",
                "null"
              ]
            },
            "label": {
              "description": "Visible label.",
              "type": "string"
            },
            "name": {
              "description": "`name` attribute.",
              "type": "string"
            },
            "type": {
              "enum": [
                "readonly"
              ],
              "type": "string"
            },
            "value": {
              "description": "Display value.",
              "type": "string"
            }
          },
          "required": [
            "label",
            "name",
            "type",
            "value"
          ],
          "type": "object"
        }
      ]
    },
    "CmsFormStep": {
      "additionalProperties": false,
      "description": "One step inside a [`CmsSection::Form`].",
      "properties": {
        "fields": {
          "description": "Fields belonging to this step.",
          "items": {
            "$ref": "#/definitions/CmsFormField"
          },
          "type": "array"
        },
        "label": {
          "description": "Step display label.",
          "type": "string"
        },
        "state": {
          "allOf": [
            {
              "$ref": "#/definitions/CmsFormStepState"
            }
          ],
          "description": "Visual state (current / upcoming / done)."
        }
      },
      "required": [
        "fields",
        "label",
        "state"
      ],
      "type": "object"
    },
    "CmsFormStepState": {
      "description": "Step visual state.",
      "oneOf": [
        {
          "description": "User is currently on this step.",
          "enum": [
            "current"
          ],
          "type": "string"
        },
        {
          "description": "Step is ahead of the user.",
          "enum": [
            "upcoming"
          ],
          "type": "string"
        },
        {
          "description": "Step has been completed.",
          "enum": [
            "done"
          ],
          "type": "string"
        }
      ]
    },
    "CmsFormSubmit": {
      "additionalProperties": false,
      "description": "Submit-row config for [`CmsSection::Form`].",
      "properties": {
        "action": {
          "description": "`<form action>` URL. Validated via `is_safe_url`.",
          "type": "string"
        },
        "data_backend": {
          "description": "Backend key (verified by phantom_button at build time).",
          "type": "string"
        },
        "label": {
          "description": "Primary button label (e.g. \"Continue → upload\").",
          "type": "string"
        },
        "secondary_label": {
          "description": "Optional secondary button label (e.g. \"Save draft\"). None → no secondary button rendered.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "action",
        "data_backend",
        "label"
      ],
      "type": "object"
    },
    "CmsKvItem": {
      "additionalProperties": false,
      "description": "FORGE_ROADMAP item 41: one entry in a [`CmsSection::KvPair`].\n\nBUG ASSUMPTION: `key` and `value` carry no markup; renderer auto-escapes via Maud. `hint` is also escaped and rendered as a muted single-line caption — not a place for arbitrary HTML.",
      "properties": {
        "hint": {
          "description": "Optional muted caption shown below the value.",
          "type": [
            "string",
            "null"
          ]
        },
        "key": {
          "description": "Label / dt text. Auto-escaped on render.",
          "type": "string"
        },
        "value": {
          "description": "Value / dd text. Auto-escaped on render.",
          "type": "string"
        }
      },
      "required": [
        "key",
        "value"
      ],
      "type": "object"
    },
    "CmsLoading": {
      "description": "Mirror of [`PictureLoading`].",
      "oneOf": [
        {
          "description": "Lazy load.",
          "enum": [
            "lazy"
          ],
          "type": "string"
        },
        {
          "description": "Eager load.",
          "enum": [
            "eager"
          ],
          "type": "string"
        }
      ]
    },
    "CmsLogoItem": {
      "additionalProperties": false,
      "description": "T660 P1: one brand logo entry in a [`CmsSection::LogoWall`].\n\n`name` is the canonical brand name + lookup key into the future `loom-brand-icons` registry. `href` is the brand's website. Until the registry crate lands, the renderer falls back to typographic rendering (the name in `loom-font-display`).\n\nAVP-2: never carries inline SVG; the registry is the only path through which SVG markup reaches the page.",
      "properties": {
        "href": {
          "description": "Brand website URL. Auto-escaped + rendered as the wrap element if non-empty.",
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "description": "Brand name (also the lookup key into `loom-brand-icons`). Examples: \"Stripe\", \"Linear\", \"Vercel\".",
          "type": "string"
        }
      },
      "required": [
        "name"
      ],
      "type": "object"
    },
    "CmsNavLink": {
      "additionalProperties": false,
      "description": "One primary-nav link.",
      "properties": {
        "current": {
          "default": false,
          "description": "Mark this link as the current page (renders `aria-current=\"page\"`).",
          "type": "boolean"
        },
        "data_backend": {
          "description": "Backend key (verified against `backends.toml` by forge's phase_phantom_button).",
          "type": "string"
        },
        "href": {
          "description": "Same-origin path or `https://` URL.",
          "type": "string"
        },
        "label": {
          "description": "Visible label.",
          "type": "string"
        }
      },
      "required": [
        "data_backend",
        "href",
        "label"
      ],
      "type": "object"
    },
    "CmsPanel": {
      "additionalProperties": false,
      "description": "One sidebar panel inside a [`CmsSection::Sidebar`].",
      "properties": {
        "body": {
          "allOf": [
            {
              "$ref": "#/definitions/CmsPanelBody"
            }
          ],
          "description": "Body content. Discriminated by `kind`."
        },
        "title": {
          "description": "Panel heading (rendered as h2).",
          "type": "string"
        }
      },
      "required": [
        "body",
        "title"
      ],
      "type": "object"
    },
    "CmsPanelBody": {
      "description": "Typed panel body. Closed enum — adding a variant requires a renderer arm + test.",
      "oneOf": [
        {
          "additionalProperties": false,
          "description": "Ordered list of `{label, value, href?}` rows. Each row renders as a `<li>`; if `href` is set + valid, the row is wrapped in an `<a>`.",
          "properties": {
            "items": {
              "description": "Row entries, top to bottom.",
              "items": {
                "$ref": "#/definitions/CmsPanelListItem"
              },
              "type": "array"
            },
            "kind": {
              "enum": [
                "list"
              ],
              "type": "string"
            }
          },
          "required": [
            "items",
            "kind"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "description": "Plain prose paragraph(s), each entry → one `<p>`.",
          "properties": {
            "kind": {
              "enum": [
                "text"
              ],
              "type": "string"
            },
            "paragraphs": {
              "description": "Paragraphs.",
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          },
          "required": [
            "kind",
            "paragraphs"
          ],
          "type": "object"
        }
      ]
    },
    "CmsPanelListItem": {
      "additionalProperties": false,
      "description": "One row inside a [`CmsPanelBody::List`].",
      "properties": {
        "data_backend": {
          "description": "Optional backend key (verified by phantom_button at build).",
          "type": [
            "string",
            "null"
          ]
        },
        "href": {
          "description": "Optional click target. Validated via `is_safe_url`.",
          "type": [
            "string",
            "null"
          ]
        },
        "label": {
          "description": "Left-side label.",
          "type": "string"
        },
        "value": {
          "description": "Right-side value.",
          "type": "string"
        }
      },
      "required": [
        "label",
        "value"
      ],
      "type": "object"
    },
    "CmsPriority": {
      "description": "Mirror of [`PicturePriority`].",
      "oneOf": [
        {
          "description": "Browser default.",
          "enum": [
            "auto"
          ],
          "type": "string"
        },
        {
          "description": "Pre-load high.",
          "enum": [
            "high"
          ],
          "type": "string"
        },
        {
          "description": "De-prioritize.",
          "enum": [
            "low"
          ],
          "type": "string"
        }
      ]
    },
    "CmsPromptAction": {
      "description": "Closed enum mirror of [`PromptAction`] — separated so the wire format is independent of the Loom enum's internals.",
      "oneOf": [
        {
          "description": "Map → [`PromptAction::UploadClip`].",
          "enum": [
            "upload_clip"
          ],
          "type": "string"
        },
        {
          "description": "Map → [`PromptAction::ChallengeOpponent`].",
          "enum": [
            "challenge_opponent"
          ],
          "type": "string"
        },
        {
          "description": "Map → [`PromptAction::GoLive`].",
          "enum": [
            "go_live"
          ],
          "type": "string"
        },
        {
          "description": "Map → [`PromptAction::PhotoOnly`].",
          "enum": [
            "photo_only"
          ],
          "type": "string"
        }
      ]
    },
    "CmsSection": {
      "description": "One section of a page. Adding a variant requires a paired renderer arm in [`render_section`] and a unit test.",
      "oneOf": [
        {
          "additionalProperties": false,
          "description": "Top-of-page hero. Optional eyebrow pill, required title, optional lede, optional primary CTA. Loom-namespaced (no Tailwind dependency) so it composes cleanly with the SkillShots PoC skin.",
          "properties": {
            "cta": {
              "anyOf": [
                {
                  "$ref": "#/definitions/HeroCta"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Optional primary CTA."
            },
            "eyebrow": {
              "description": "Optional small pill above the title.",
              "type": [
                "string",
                "null"
              ]
            },
            "kind": {
              "enum": [
                "hero"
              ],
              "type": "string"
            },
            "lede": {
              "description": "Optional subhead paragraph.\n\nREGRESSION-GUARD: serde alias `subtitle` accepts the pre-2026-05 field name. Older fixture files written by the form-builder still use `subtitle`; without the alias the renderer 500s on read because `deny_unknown_fields` rejects unknown keys. Save-path scrubbing handles the write side; this handles the read side. Cycle 52 /preview-edit/about.html 500 was the trigger.",
              "type": [
                "string",
                "null"
              ]
            },
            "title": {
              "description": "Headline text.",
              "type": "string"
            }
